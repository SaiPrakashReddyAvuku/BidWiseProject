# Spring Boot datasource settings
DB_URL=jdbc:mysql://localhost:3306/bidwise?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=bidwise
DB_PASSWORD=replace_with_real_password
DB_POOL_MAX_SIZE=10

# JPA settings
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT settings (use a strong base64-encoded secret in production)
JWT_SECRET=replace_with_base64_secret
JWT_EXPIRATION_MINUTES=120

# Stripe settings
STRIPE_API_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret

# Mail settings
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_smtp_user
MAIL_PASSWORD=replace_with_smtp_password
MAIL_FROM=no-reply@bidwise.local
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_SMTP_STARTTLS_REQUIRED=true

# Optional Docker MySQL container settings
MYSQL_DATABASE=bidwise
MYSQL_ROOT_PASSWORD=replace_with_real_password
MYSQL_USER=bidwise
MYSQL_PASSWORD=replace_with_real_password

# Seed data for local development
APP_SEED_DATA=true
